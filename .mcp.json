{
  "mcpServers": {
    "fiori-mcp": {
      "type": "stdio",
      "timeout": 600,
      "command": "npx",
      "args": ["--yes", "@sap-ux/fiori-mcp-server@latest", "fiori-mcp"],
      "env": {
        "LOG_LEVEL": "debug"
      }
    },
    "@ui5/mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": ["@ui5/mcp-server"]
    },
    "cds-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@cap-js/mcp-server"]
    }
  }
}